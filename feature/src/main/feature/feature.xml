<features name="${project.artifactId}-${project.version}"
  xmlns="http://karaf.apache.org/xmlns/features/v1.4.0">

  <feature description='${project.name}' name='${project.artifactId}' start-level="75"
    version='${project.version}'>
    <config name="org.apache.aries.jax.rs.whiteboard.default">
      default.web=false
      application.base.prefix=/
    </config>
    <config name="org.apache.felix.fileinstall-camel">
      felix.fileinstall.dir = ${env:RAHLA_DEPLOY_PATH:-/deploy/}
      felix.fileinstall.filter = .*\\.(xml|cfg|groovy)
      felix.fileinstall.poll = 1000
      felix.fileinstall.start.level = 80
      felix.fileinstall.active.level  = 100
      felix.fileinstall.log.level = 3
    </config>

    <feature>jolokia</feature>
    <feature>aries-jax-rs-whiteboard</feature>
    <feature>aries-jax-rs-whiteboard-jackson</feature>
    <feature>camel-core</feature>
    <feature>camel-http</feature>
    <feature>camel-blueprint</feature>
    <feature>camel-openapi-java</feature>
    <feature>camel-jetty</feature>
    <feature>camel-jackson</feature>
    <feature>camel-base64</feature>
    <feature>camel-metrics</feature>
    <feature>camel-opentelemetry</feature>
    <feature>camel-opentracing</feature>

    <bundle dependency="true">
      mvn:org.apache.servicemix.specs/org.apache.servicemix.specs.jaxws-api-2.2/2.9.0
    </bundle>
    <bundle dependency="true">
      mvn:org.apache.servicemix.specs/org.apache.servicemix.specs.saaj-api-1.3/2.9.0
    </bundle>

    <bundle dependency='true'>mvn:net.minidev/json-smart/${json-smart-version}</bundle>
    <bundle dependency='true'>mvn:net.minidev/accessors-smart/${json-smart-version}</bundle>
    <bundle dependency='true'>mvn:org.ow2.asm/asm/${asm.bundle.version}</bundle>
    <bundle dependency='true'>mvn:org.ow2.asm/asm-analysis/${asm.bundle.version}</bundle>
    <bundle dependency='true'>mvn:org.ow2.asm/asm-commons/${asm.bundle.version}</bundle>
    <bundle dependency='true'>mvn:org.ow2.asm/asm-tree/${asm.bundle.version}</bundle>
    <bundle dependency='true'>mvn:org.ow2.asm/asm-util/${asm.bundle.version}</bundle>

  </feature>


</features>