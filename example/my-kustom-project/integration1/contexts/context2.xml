<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
  xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0">
  <cm:property-placeholder id="config.props" persistent-id="config" update-strategy="reload"/>
  <camelContext id="context1"
    xmlns="http://camel.apache.org/schema/blueprint">

    <propertyPlaceholder id="properties" location="blueprint:config.props"/>


    <route id="route1">
      <from uri="mock:bar"/>
      <log message="${body}"/>
      <to uri="{{to.url}}"/>
    </route>

  </camelContext>

</blueprint>
