<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared build pom: turn a project's deploy/features.xml into an OFFLINE / air-gapped KAR.

  Not a Maven module and not published — projects fetch it over HTTP in their Dockerfile:
    ADD https://codeberg.org/datatactics/rahla/raw/branch/main/manifests/feature-kar.xml ./pom.xml
    COPY deploy/features.xml ./deploy/features.xml
    RUN mvn -B -q -f pom.xml package          # -> target/<feature>.kar

  WHY THE CLOSURE: the plain karaf `kar` goal only packs bundles a feature lists *directly*.
  For an air-gapped KAR (no download at startup) we need the feature's FULL bundle closure
  (camel, pax-jdbc-oracle/ojdbc, …), which is what `features-add-to-repository` resolves.

  WHY THE STUB: that closure resolver must resolve every <feature> reference at BUILD time,
  including rahla's own features (fradi, graphsource, jedissource, camel-route-templates).
  Their definitions live in rahla/dtacs, not Maven Central, so the build can't find them — and
  we don't want to bundle them anyway, because rahla already ships them and installs them
  air-gapped from its own system/ at runtime. The stub feeds the resolver an EMPTY definition
  for each, so it skips them. (Build-time only; runtime uses rahla's real features.)

  Build needs Java >= 22 (karaf tooling) -> use a JDK 22+ Maven image.
  kar.feature is auto-detected from the first <feature name="…">; override with -Dkar.feature=…
  Versions default to rahla 1.3.2 (-Dkar.karaf.version / -Dkar.camel.version to change).
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>dev.datatactics.rahla</groupId>
  <artifactId>feature-kar</artifactId>
  <version>1.0.0</version>
  <packaging>kar</packaging>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <kar.featuresFile>${project.basedir}/deploy/features.xml</kar.featuresFile>
    <kar.karaf.version>4.4.11</kar.karaf.version>
    <kar.camel.version>4.18.1</kar.camel.version>
  </properties>

  <build>
    <finalName>${kar.feature}</finalName>
    <plugins>
      <!-- auto-detect kar.feature from deploy/features.xml (so projects pass no -D) -->
      <plugin>
        <groupId>org.codehaus.gmavenplus</groupId>
        <artifactId>gmavenplus-plugin</artifactId>
        <version>3.0.2</version>
        <dependencies>
          <dependency><groupId>org.apache.groovy</groupId><artifactId>groovy</artifactId><version>4.0.22</version></dependency>
        </dependencies>
        <executions>
          <execution>
            <phase>initialize</phase>
            <goals><goal>execute</goal></goals>
            <configuration><scripts><script><![CDATA[
              if (!project.properties['kar.feature']) {
                def f = new File(project.properties['kar.featuresFile'])
                def m = (f.text =~ /<feature\s+name="([^"]+)"/)
                assert m : "no <feature name=...> found in " + f
                project.properties['kar.feature'] = m[0][1]
                log.info "feature-kar: kar.feature = " + project.properties['kar.feature']
              }
            ]]></script></scripts></configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-antrun-plugin</artifactId>
        <version>3.1.0</version>
        <executions>
          <!-- empty stubs for the features rahla provides -> resolver skips them, not bundled -->
          <execution>
            <id>rahla-stubs</id>
            <phase>generate-resources</phase>
            <goals><goal>run</goal></goals>
            <configuration><target>
              <mkdir dir="${project.build.directory}"/>
              <echo file="${project.build.directory}/rahla-stubs.xml"><![CDATA[<features name="rahla-provided" xmlns="http://karaf.apache.org/xmlns/features/v1.6.0"><feature name="fradi" version="0"/><feature name="graphsource" version="0"/><feature name="jedissource" version="0"/><feature name="camel-route-templates" version="0"/></features>]]></echo>
            </target></configuration>
          </execution>
          <!-- merge the resolved closure jars into the KAR built by the kar goal -->
          <execution>
            <id>merge-closure</id>
            <phase>package</phase>
            <goals><goal>run</goal></goals>
            <configuration><target>
              <jar destfile="${project.build.directory}/${project.build.finalName}.kar" update="true">
                <fileset dir="${project.build.directory}/closure" includes="repository/**/*.jar"/>
              </jar>
            </target></configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.karaf.tooling</groupId>
        <artifactId>karaf-maven-plugin</artifactId>
        <version>${kar.karaf.version}</version>
        <extensions>true</extensions>
        <configuration><featuresFile>${kar.featuresFile}</featuresFile></configuration>
        <executions>
          <execution>
            <id>closure</id>
            <phase>prepare-package</phase>
            <goals><goal>features-add-to-repository</goal></goals>
            <configuration>
              <descriptors>
                <descriptor>file:${kar.featuresFile}</descriptor>
                <descriptor>file:${project.build.directory}/rahla-stubs.xml</descriptor>
                <descriptor>mvn:org.apache.karaf.features/framework/${kar.karaf.version}/xml/features</descriptor>
                <descriptor>mvn:org.apache.karaf.features/specs/${kar.karaf.version}/xml/features</descriptor>
                <descriptor>mvn:org.apache.karaf.features/standard/${kar.karaf.version}/xml/features</descriptor>
                <descriptor>mvn:org.apache.karaf.features/enterprise/${kar.karaf.version}/xml/features</descriptor>
                <descriptor>mvn:org.apache.camel.karaf/apache-camel/${kar.camel.version}/xml/features</descriptor>
              </descriptors>
              <features><feature>${kar.feature}</feature></features>
              <repository>${project.build.directory}/closure/repository</repository>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
