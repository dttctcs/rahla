<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared "features.xml -> offline KAR" build for Rahla projects.

  This pom is NOT a Maven module of the rahla reactor and is NOT published to a Maven repo.
  Projects fetch it straight from this repo (main) in their Dockerfile, e.g.:

    ADD https://codeberg.org/datatactics/rahla/raw/branch/main/manifests/feature-kar.xml ./pom.xml
    COPY deploy/features.xml ./deploy/features.xml
    RUN mvn -f pom.xml package -Dkar.feature=<feature> -Dkar.karaf.version=<v> -Dkar.camel.version=<v>

  It resolves the named feature out of the project's features.xml and packs it plus its full
  bundle closure into one offline-installable KAR (kar:install / drop in /config/deploy). Features
  rahla already ships (fradi, graphsource, jedissource, camel-route-templates) are stubbed out so
  the build needs only Maven Central (no dtacs repo) and the KAR stays a minimal delta.

  Parameters (-D...):
    kar.feature         which feature in the features.xml to resolve            (required)
    kar.featuresFile    path to the features.xml   (default: ${basedir}/deploy/features.xml)
    kar.karaf.version   karaf feature-repo version, MUST match the target rahla (default 4.4.11 = rahla 1.3.2)
    kar.camel.version   apache-camel feature-repo version, match target rahla   (default 4.18.1 = rahla 1.3.2)

  Note: karaf-maven-plugin 4.4.x requires Java >= 22 at build time -> use a JDK 22+ maven image.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>dev.datatactics.rahla</groupId>
  <artifactId>feature-kar</artifactId>
  <version>1.0.0</version>
  <packaging>kar</packaging>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <kar.featuresFile>${project.basedir}/deploy/features.xml</kar.featuresFile>
    <kar.karaf.version>4.4.11</kar.karaf.version>
    <kar.camel.version>4.18.1</kar.camel.version>
  </properties>

  <build>
    <!-- the KAR is named after the feature, e.g. fuel.kar -->
    <finalName>${kar.feature}</finalName>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-antrun-plugin</artifactId>
        <version>3.1.0</version>
        <executions>
          <!-- generate the rahla-provided-feature stubs so they are NOT bundled (rahla has them) -->
          <execution>
            <id>rahla-stubs</id>
            <phase>generate-resources</phase>
            <goals><goal>run</goal></goals>
            <configuration><target>
              <mkdir dir="${project.build.directory}"/>
              <echo file="${project.build.directory}/rahla-stubs.xml"><![CDATA[<features name="rahla-provided" xmlns="http://karaf.apache.org/xmlns/features/v1.6.0"><feature name="fradi" version="0"/><feature name="graphsource" version="0"/><feature name="jedissource" version="0"/><feature name="camel-route-templates" version="0"/></features>]]></echo>
            </target></configuration>
          </execution>
          <!-- merge the resolved closure jars into the KAR the kar-goal built (jars only) -->
          <execution>
            <id>merge-closure</id>
            <phase>package</phase>
            <goals><goal>run</goal></goals>
            <configuration><target>
              <jar destfile="${project.build.directory}/${project.build.finalName}.kar" update="true">
                <fileset dir="${project.build.directory}/closure" includes="repository/**/*.jar"/>
              </jar>
            </target></configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.karaf.tooling</groupId>
        <artifactId>karaf-maven-plugin</artifactId>
        <version>${kar.karaf.version}</version>
        <extensions>true</extensions>
        <!-- kar packaging: builds the KAR with the feature descriptor + the directly-listed bundles -->
        <configuration><featuresFile>${kar.featuresFile}</featuresFile></configuration>
        <executions>
          <!-- resolve the named feature's full bundle closure (camel, pax-jdbc, ... via Central) -->
          <execution>
            <id>closure</id>
            <phase>prepare-package</phase>
            <goals><goal>features-add-to-repository</goal></goals>
            <configuration>
              <descriptors>
                <descriptor>file:${kar.featuresFile}</descriptor>
                <descriptor>file:${project.build.directory}/rahla-stubs.xml</descriptor>
                <descriptor>mvn:org.apache.karaf.features/framework/${kar.karaf.version}/xml/features</descriptor>
                <descriptor>mvn:org.apache.karaf.features/specs/${kar.karaf.version}/xml/features</descriptor>
                <descriptor>mvn:org.apache.karaf.features/standard/${kar.karaf.version}/xml/features</descriptor>
                <descriptor>mvn:org.apache.karaf.features/enterprise/${kar.karaf.version}/xml/features</descriptor>
                <descriptor>mvn:org.apache.camel.karaf/apache-camel/${kar.camel.version}/xml/features</descriptor>
              </descriptors>
              <features><feature>${kar.feature}</feature></features>
              <repository>${project.build.directory}/closure/repository</repository>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
