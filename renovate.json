{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Only open PRs for major version updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest",
        "bump",
        "rollback"
      ],
      "enabled": false
    }
  ]
}
